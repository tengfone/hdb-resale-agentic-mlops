# HDB Resale MLOps environment template
# Copy this file to .env and uncomment the values you need.
#
# Local / Colab:
# - All settings are optional.
# - If MLFLOW_TRACKING_URI is unset, the notebook falls back to sqlite:///mlflow.db.
# - Local users can ignore the SageMaker and Network / proxy sections below.
#
# Enterprise / SageMaker:
# - Set MLFLOW_TRACKING_URI to your remote MLflow server when you want notebook-side logging to use it instead of the local SQLite fallback.
# - SageMaker notebooks usually auto-detect AWS_REGION, SAGEMAKER_ROLE_ARN, and S3_BUCKET,
#   but you can still pin them here when needed.

# ── MLflow ──
# MLFLOW_TRACKING_URI=sqlite:///mlflow.db
# MLFLOW_TRACKING_USERNAME=
# MLFLOW_TRACKING_PASSWORD=
# MLFLOW_MODEL_NAME=hdb-resale-price-regressor
# MLFLOW_EXPERIMENT_NAME=hdb-resale-candidate

# ── Data / split config ──
# HDB_DATA_COLLECTION_ID=189
# HDB_DATASET_ID=d_8b84c4ee58e3cfc0ece0d773c8ca6abc
# HDB_DATASET_NAME=hdb-resale-prices-2017-onward
# DATA_GOV_API_KEY=
# RANDOM_SEED=7
# VALIDATION_MONTHS=12
# TEST_MONTHS=12

# ── SageMaker ──
# AWS_REGION=ap-southeast-1
# SAGEMAKER_ROLE_ARN=arn:aws:iam::<account-id>:role/<role-name>
# S3_BUCKET=<bucket-name>
# SAGEMAKER_FRAMEWORK_VERSION=1.4-2
# SAGEMAKER_INSTANCE_TYPE=ml.m5.xlarge
# SAGEMAKER_INSTANCE_COUNT=1
# SAGEMAKER_MAX_RUN_SECONDS=3600
# TRAINING_JOB_PREFIX=hdb-resale

# ── Agentic workflow ──
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5-nano      # Example if using OpenRouter: qwen/qwen3.6-plus:free
# OPENAI_BASE_URL=             # To put a v1 compatible endpoint, e.g. https://openrouter.ai/api/v1
# ENABLE_JUDGE_EVAL=true
# MARKET_RESEARCH_PROVIDER=auto
# OPENAI_WEB_SEARCH_MODEL=gpt-5-nano
# TAVILY_API_KEY=
# OPENAI_JUDGE_MODEL=gpt-5-mini
# MODEL_REVIEWER=

# ── Network / proxy (enterprise only) ──
# MAESTRO_HTTP_PROXY=http://<proxy-host>:<port>
# MAESTRO_HTTPS_PROXY=http://<proxy-host>:<port>
# TRAINING_PIP_INDEX_URL=https://<pypi-mirror>/simple/
# PIP_INDEX_URL=https://<pypi-mirror>/simple/
